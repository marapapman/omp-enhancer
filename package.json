{
  "name": "omp-enhancer-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "plugins/omp-config",
    "plugins/writing-helper",
    "plugins/omp-test-enhancer",
    "plugins/omp-fact-checker",
    "plugins/omp-enhancer-core"
  ],
  "scripts": {
    "test": "npm run check:workflows && node --test scripts/*.test.js && npm test --workspaces --if-present",
    "generate:workflows": "node scripts/generate-workflow-catalog.js --write",
    "check:workflows": "node scripts/generate-workflow-catalog.js --check",
    "pack:all": "node scripts/pack-all.js",
    "check:marketplace": "node scripts/check-marketplace.js",
    "release": "node scripts/release.js",
    "e2e:deepseek": "node scripts/e2e/run-installed-deepseek-workflow.mjs",
    "e2e:deepseek:advisor": "node scripts/e2e/run-installed-deepseek-workflow.mjs --matrix scripts/e2e/fixtures/deepseek-advisor-stress.json",
    "migrate:legacy-gate-skills": "node scripts/migrate-legacy-gate-skills.mjs"
  }
}
