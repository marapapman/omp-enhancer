{
  "name": "omp-config",
  "version": "0.1.34",
  "private": true,
  "type": "module",
  "description": "Optional OMP workflow references, config assets, uniquely named agents, notify-only hooks, opt-in hook templates, and diagnostics.",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "src",
    "commands",
    "agents",
    "skills",
    "hooks",
    "hook-templates",
    "assets",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "pack:dry": "npm pack --dry-run"
  },
  "omp": {
    "extensions": [
      "./index.js"
    ]
  },
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "keywords": [
    "pi-package",
    "omp",
    "omp-plugin",
    "config",
    "skills",
    "agents",
    "hooks"
  ],
  "license": "UNLICENSED"
}
