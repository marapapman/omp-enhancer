# ──── OMP Agent 环境变量 ────
# 复制为 ~/.omp/agent/.env 并填入实际值
# 此文件可安全提交（不含密钥）

# OpenCode Go API（主提供方）
OPENCODE_API_KEY=

# DeepSeek 直连 API（兜底）
DEEPSEEK_API_KEY=

# 自托管 OpenAI 兼容 API
SELFHOSTED_OPENAI_API_KEY=

# NekoCode Claude 代理（Anthropic）
NEKOCODE_CLAUDE_API_KEY=

# NekoCode OpenAI 代理（GPT 系列）
NEKOCODE_OPENAI_API_KEY=

# Jina AI（可选）
JINA_API_KEY=

# GitHub MCP Token（mcp.json 中 github 服务使用）
GITHUB_MCP_TOKEN=
