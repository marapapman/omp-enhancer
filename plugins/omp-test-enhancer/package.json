{
  "name": "omp-testing-enhancer",
  "version": "0.1.17",
  "description": "OMP plugin with advisory testing analysis, host-observed evidence, browser, coverage, mutation, review, and reporting tools.",
  "type": "module",
  "main": "./dist/extension.js",
  "exports": {
    ".": "./dist/extension.js"
  },
  "files": [
    "dist",
    "src",
    "tools",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "test": "bunx vitest run",
    "prepack": "bun run build"
  },
  "dependencies": {
    "pixelmatch": "latest",
    "playwright": "latest",
    "pngjs": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pngjs": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "omp": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marapapman/omp-enhancer.git",
    "directory": "plugins/omp-test-enhancer"
  }
}
