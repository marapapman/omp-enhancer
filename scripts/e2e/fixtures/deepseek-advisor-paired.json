{
  "version": 1,
  "defaults": {
    "model": "opencode-go/deepseek-v4-flash",
    "thinking": "max",
    "approvalMode": "yolo",
    "executionMode": "rpc",
    "tools": ["read"],
    "repeat": 5,
    "timeoutSeconds": 180,
    "expectations": {
      "noWeb": true,
      "requireFinal": true,
      "maxPrimaryFinals": 1,
      "maxPostFinalAdvisorMessages": 0,
      "noUnobservedSkillClaims": true,
      "requireSuccessfulToolCalls": true,
      "maxDuplicateFailedCalls": 0,
      "maxDuplicateSkillReadAttempts": 0,
      "maxProvidedSkills": 0,
      "expectedProvisionMode": "none",
      "requireWorkflowIndexOnlyFirstToolBatch": true,
      "requireWorkflowPlanBeforeResourceLoads": true,
      "requireStructuredWorkflowLoadPhases": true,
      "requiredWorkflowPlanFormat": "block",
      "minWorkflowPlanNumberedActions": 4,
      "forbidResourceProjectSameBatch": true,
      "requireWorkflowReadyAfterLoadsBeforeProjectTools": true,
      "requireExactSelectedWorkflowReferences": true,
      "requireWorkflowPlanSkillsUseDomainSkillUris": true,
      "requireWorkflowReadyLoadedSkillsUseBareIds": true,
      "requireWorkflowReadyLoadedSkillsMatchSuccessfulDomainSkills": true,
      "minWorkflowReferenceReads": 1,
      "requiredSelectedWorkflowIds": ["writing.en", "writing.latex"],
      "requiredAnySkills": ["writing-review", "polish-acm-latex-prose"],
      "maxObservedSkills": 2,
      "forbiddenSkills": ["plain-chinese-writing", "zh-writing-polish", "writing-markdown-helper"],
      "maxToolCalls": 8,
      "maxSourceSearchCalls": 8,
      "maxAbortedAssistants": 0,
      "pluginContinuationCount": 0
    }
  },
  "scenarios": [
    {
      "id": "writing-main-only",
      "category": "paired/main-only",
      "fixture": "skill-discovery-readonly",
      "advisor": false,
      "prompt": "Read abstract.tex and propose a conservative correction of its single English sentence. Preserve all qualifiers, modality, negation, percentages, citations, and LaTeX commands. Do not modify files or use the network.",
      "expectations": {
        "maxAdvisorMessages": 0
      }
    },
    {
      "id": "writing-with-advisor",
      "category": "paired/advisor",
      "fixture": "skill-discovery-readonly",
      "advisor": true,
      "prompt": "Read abstract.tex and propose a conservative correction of its single English sentence. Preserve all qualifiers, modality, negation, percentages, citations, and LaTeX commands. Do not modify files or use the network.",
      "expectations": {
        "maxAdvisorMessages": 1
      }
    },
    {
      "id": "zh-writing-skill-uri-with-advisor",
      "category": "paired/advisor-zh",
      "fixture": "semantic-edit-zh",
      "advisor": true,
      "repeat": 1,
      "prompt": "Read paper.md and propose a conservative Chinese polish. Preserve every fact, qualifier, citation, number, and Markdown structure. Do not modify files or use the network.",
      "expectations": {
        "maxAdvisorMessages": 1,
        "requiredWorkflowPrimary": "writing.zh",
        "requiredSelectedWorkflowIds": ["writing.zh"],
        "forbiddenSelectedWorkflowIds": ["writing.en", "writing.latex"],
        "requiredAnySkills": [],
        "requiredObservedSkills": ["plain-chinese-writing", "zh-writing-polish"],
        "requiredObservedSkillsBeforeProjectTools": ["plain-chinese-writing", "zh-writing-polish"],
        "requiredExactSkillUrisBeforeProjectTools": ["skill://plain-chinese-writing", "skill://zh-writing-polish"],
        "maxObservedSkills": 3,
        "forbiddenSkills": ["writing-review", "polish-acm-latex-prose", "writing-markdown-helper"],
        "forbidMisaddressedDeclaredSkillReads": true,
        "forbidUnsupportedAdvisorSkillAbsenceClaims": true
      }
    }
  ]
}
