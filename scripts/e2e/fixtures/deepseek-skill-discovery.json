{
  "version": 1,
  "defaults": {
    "model": "opencode-go/deepseek-v4-flash",
    "thinking": "high",
    "approvalMode": "yolo",
    "advisor": false,
    "executionMode": "rpc",
    "tools": ["read"],
    "repeat": 1,
    "timeoutSeconds": 150,
    "expectations": {
      "noWeb": true,
      "requireFinal": true,
      "maxPrimaryFinals": 1,
      "maxAdvisorMessages": 0,
      "noUnobservedSkillClaims": true,
      "requireSuccessfulToolCalls": true,
      "maxDuplicateFailedCalls": 0,
      "maxDuplicateSkillReadAttempts": 0,
      "maxProvidedSkills": 0,
      "expectedProvisionMode": "none",
      "requireWorkflowIndexOnlyFirstToolBatch": true,
      "requireWorkflowPlanBeforeResourceLoads": true,
      "requireStructuredWorkflowLoadPhases": true,
      "requiredWorkflowPlanFormat": "block",
      "minWorkflowPlanNumberedActions": 4,
      "forbidResourceProjectSameBatch": true,
      "requireWorkflowReadyAfterLoadsBeforeProjectTools": true,
      "requireExactSelectedWorkflowReferences": true,
      "requireWorkflowPlanSkillsUseDomainSkillUris": true,
      "requireWorkflowReadyLoadedSkillsUseBareIds": true,
      "requireWorkflowReadyLoadedSkillsMatchSuccessfulDomainSkills": true,
      "maxToolCalls": 8,
      "maxSourceSearchCalls": 8,
      "maxAbortedAssistants": 0,
      "pluginContinuationCount": 0
    }
  },
  "scenarios": [
    {
      "id": "fixture-xlsx-control",
      "category": "harness-control",
      "fixture": "skill-discovery-readonly",
      "prompt": "Read skill://xlsx and return only its first Markdown heading. Do not read project files.",
      "expectations": {
        "requireWorkflowIndexOnlyFirstToolBatch": false,
        "requireWorkflowPlanBeforeResourceLoads": false,
        "requireStructuredWorkflowLoadPhases": false,
        "forbidResourceProjectSameBatch": false,
        "requireWorkflowReadyAfterLoadsBeforeProjectTools": false,
        "requireWorkflowPlanSkillsUseDomainSkillUris": false,
        "requireWorkflowReadyLoadedSkillsUseBareIds": false,
        "requireWorkflowReadyLoadedSkillsMatchSuccessfulDomainSkills": false,
        "forbidWorkflowMarkers": true,
        "expectedToolSequence": ["read"],
        "requiredObservedSkills": ["xlsx"],
        "maxObservedSkills": 1,
        "maxToolCalls": 1,
        "forbiddenSkills": ["omp-enhancer-workflows"]
      }
    },
    {
      "id": "natural-writing-en",
      "category": "writing-helper",
      "fixture": "skill-discovery-readonly",
      "prompt": "Read abstract.tex and propose a conservative correction of its single English sentence. Preserve all qualifiers, modality, negation, percentages, citations, and LaTeX commands. Do not modify files or use the network.",
      "expectations": {
        "minWorkflowReferenceReads": 1,
        "requiredSelectedWorkflowIds": ["writing.en", "writing.latex"],
        "requiredAnySkills": ["writing-review", "polish-acm-latex-prose"],
        "maxObservedSkills": 2,
        "forbiddenSkills": ["plain-chinese-writing", "zh-writing-polish", "writing-markdown-helper"]
      }
    },
    {
      "id": "natural-fact-check",
      "category": "fact-checker",
      "fixture": "skill-discovery-readonly",
      "prompt": "Check the three claims in claims.md against evidence.md using only local evidence. Give a separate verdict for each claim and state limitations. Do not modify files or use the network.",
      "expectations": {
        "minWorkflowReferenceReads": 1,
        "requiredObservedSkills": ["fact-checking"],
        "requiredObservedSkillsBeforeProjectTools": ["fact-checking"],
        "maxObservedSkills": 4,
        "forbiddenSkills": ["writing-review"],
        "requiredClaimVerdicts": {
          "1": ["INSUFFICIENT", "LOCAL_UNVERIFIED"],
          "2": "CONTRADICTED",
          "3": ["INSUFFICIENT", "LOCAL_UNVERIFIED"]
        }
      }
    },
    {
      "id": "natural-docker-compose",
      "category": "omp-config",
      "fixture": "skill-discovery-readonly",
      "prompt": "Audit docker-compose.yml for production safety, current Compose syntax, secret handling, port exposure, persistence, and a health check. Return evidence-backed findings only; do not modify files or run containers.",
      "expectations": {
        "minWorkflowReferenceReads": 1,
        "requiredObservedSkills": ["docker-compose"],
        "maxObservedSkills": 2,
        "forbiddenSkills": ["frontend-design", "webapp-testing"]
      }
    },
    {
      "id": "natural-workflow-reference",
      "category": "omp-config",
      "fixture": "skill-discovery-readonly",
      "prompt": "Consult the optional OMP Enhancer workflow reference already available in this session, then create a compact, ordered release-readiness checklist for a six-plugin OMP marketplace. Cover implementation validation, independent security review, package verification, rollback readiness, and separate publish authorization. Explain which phases can be composed. Do not inspect or modify project files.",
      "expectations": {
        "minWorkflowReferenceReads": 1,
        "requiredObservedSkills": ["omp-enhancer-workflows"],
        "maxObservedSkills": 6,
        "forbiddenSkills": ["writing-review", "docker-compose"]
      }
    },
    {
      "id": "natural-tikz-diagram",
      "category": "tikz-helper",
      "fixture": "skill-discovery-readonly",
      "prompt": "Plan an editable TikZ approval flowchart with six labeled nodes, one decision branch, and one missing custom pictogram. Use the packaged OpenTikZ material, assume image generation is unavailable, preserve all labels and topology in TikZ, and require current-revision compile plus independent visual evidence. Do not inspect or modify project files and do not use the network.",
      "expectations": {
        "minWorkflowReferenceReads": 1,
        "requiredSelectedWorkflowIds": ["diagram.tikz"],
        "requiredObservedSkills": ["tikz-diagram"],
        "maxObservedSkills": 6,
        "forbiddenSkills": ["svg-writing", "writing-review", "writing-markdown-helper"]
      }
    },
    {
      "id": "natural-xlsx",
      "category": "omp-user-skill",
      "fixture": "skill-discovery-readonly",
      "prompt": "Read sales.csv and specify the exact workbook structure, formulas, professional formatting, validation checks, and chart you would use to deliver sales.xlsx. This is a read-only planning run, so do not create the file.",
      "expectations": {
        "minWorkflowReferenceReads": 1,
        "requiredObservedSkills": ["xlsx"],
        "maxObservedSkills": 2,
        "forbiddenSkills": ["pdf", "pptx"]
      }
    },
    {
      "id": "natural-ecc-nested",
      "category": "omp-config-ecc",
      "fixture": "skill-discovery-readonly",
      "prompt": "Create a concise troubleshooting checklist for a home Pi-hole installation where DHCP clients intermittently bypass local DNS and DNS-over-HTTPS is enabled. Distinguish router, DHCP, client, upstream, and cache checks. Do not inspect files, change configuration, or use the network.",
      "expectations": {
        "minWorkflowReferenceReads": 1,
        "requiredObservedSkills": ["homelab-pihole-dns"],
        "forbiddenSkills": ["ecc-skill-catalog", "docker-compose", "frontend-design", "xlsx"],
        "maxObservedSkills": 3
      }
    },
    {
      "id": "natural-subagent-isolation",
      "category": "omp-native-agent-control",
      "fixture": "skill-discovery-readonly",
      "prompt": "Use exactly one native scout subagent to read README.md and return its first Markdown heading. The parent must not read the file itself. Do not modify files or use the network.",
      "tools": ["task", "hub", "read"],
      "expectations": {
        "requireSuccessfulToolCalls": false,
        "requireWorkflowIndexOnlyFirstToolBatch": false,
        "requireWorkflowPlanBeforeResourceLoads": false,
        "requireStructuredWorkflowLoadPhases": false,
        "forbidResourceProjectSameBatch": false,
        "requireWorkflowReadyAfterLoadsBeforeProjectTools": false,
        "requireWorkflowPlanSkillsUseDomainSkillUris": false,
        "requireWorkflowReadyLoadedSkillsUseBareIds": false,
        "requireWorkflowReadyLoadedSkillsMatchSuccessfulDomainSkills": false,
        "forbidWorkflowMarkers": true,
        "maxNativeTodoCalls": 0,
        "maxObservedSkills": 0,
        "minNativeTaskCalls": 1,
        "maxNativeTaskCalls": 1,
        "minNativeTaskForks": 1,
        "maxNativeTaskAssignmentAttempts": 1,
        "requireNativeTaskCompletion": true,
        "forbiddenSkills": ["writing-review", "fact-checking", "docker-compose", "omp-enhancer-workflows", "xlsx", "ecc-skill-catalog"]
      }
    },
    {
      "id": "natural-negative-read",
      "category": "negative-control",
      "fixture": "skill-discovery-readonly",
      "prompt": "Read README.md and return only its first Markdown heading. Do not modify files.",
      "tools": ["todo", "task", "hub", "read"],
      "expectations": {
        "requireWorkflowIndexOnlyFirstToolBatch": false,
        "requireWorkflowPlanBeforeResourceLoads": false,
        "requireStructuredWorkflowLoadPhases": false,
        "forbidResourceProjectSameBatch": false,
        "requireWorkflowReadyAfterLoadsBeforeProjectTools": false,
        "requireWorkflowPlanSkillsUseDomainSkillUris": false,
        "requireWorkflowReadyLoadedSkillsUseBareIds": false,
        "requireWorkflowReadyLoadedSkillsMatchSuccessfulDomainSkills": false,
        "forbidWorkflowMarkers": true,
        "expectedToolSequence": ["read"],
        "maxNativeTodoCalls": 0,
        "maxNativeTaskCalls": 0,
        "maxObservedSkills": 0,
        "forbiddenSkills": ["writing-review", "fact-checking", "docker-compose", "omp-enhancer-workflows", "xlsx", "pdf", "frontend-design", "webapp-testing", "ecc-skill-catalog"]
      }
    }
  ]
}
