        "minNativeTaskCalls": 1,
        "maxNativeTaskCalls": 1,
        "minNativeTaskAssignmentAttempts": 1,
        "maxNativeTaskAssignmentAttempts": 1,
        "requireNativeTaskCompletion": true,
