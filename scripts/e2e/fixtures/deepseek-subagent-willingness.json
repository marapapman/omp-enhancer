{
  "version": 1,
  "defaults": {
    "model": "opencode-go/deepseek-v4-flash",
    "thinking": "high",
    "approvalMode": "yolo",
    "advisor": false,
    "executionMode": "rpc",
    "taskEager": "preferred",
    "tools": ["task", "hub", "read", "grep", "glob"],
    "repeat": 3,
    "timeoutSeconds": 360,
    "expectations": {
      "noWeb": true,
      "requireFinal": true,
      "maxPrimaryFinals": 1,
      "maxAdvisorMessages": 0,
      "requireSuccessfulToolCalls": false,
      "maxDuplicateFailedCalls": 0,
      "maxToolCalls": 30,
      "maxSourceSearchCalls": 20,
      "requiredWorkflowPlanFormat": "block",
      "minWorkflowPlanNumberedActions": 1,
      "pluginContinuationCount": 0
    }
  },
  "scenarios": [
    {
      "id": "single-read-direct",
      "category": "negative/single-target",
      "cwd": ".",
      "prompt": "Read README.md and return only its first Markdown heading. Do not modify files or use the network.",
      "expectations": {
        "maxNativeTaskCalls": 0,
        "maxNativeTaskAssignmentAttempts": 0,
        "maxNativeTodoCalls": 0,
        "forbidWorkflowMarkers": true,
        "forbiddenSkills": ["omp-enhancer-workflows"]
      }
    },
    {
      "id": "explicit-main-only",
      "category": "negative/user-constraint",
      "cwd": ".",
      "prompt": "Inspect all five workspace plugin package manifests and entry files, but keep all work in the main agent and do not delegate any part. Report only whether every declared entry exists. Do not modify files, run tests, or use the network.",
      "expectations": {
        "maxNativeTaskCalls": 0,
        "maxNativeTaskAssignmentAttempts": 0,
        "requiredObservedSkills": ["code-development", "omp-enhancer-workflows"],
        "requireWorkflowIndexOnlyFirstToolBatch": true,
        "requireWorkflowPlanBeforeResourceLoads": true,
        "forbidResourceProjectSameBatch": true,
        "requireWorkflowReadyAfterLoadsBeforeProjectTools": true,
        "requireExactSelectedWorkflowReferences": true
      }
    },
    {
      "id": "two-trivial-lookups-direct",
      "category": "negative/trivial-batch",
      "cwd": ".",
      "prompt": "Read plugins/omp-enhancer-core/package.json and plugins/omp-config/package.json and return only the name field from each file. Do not modify files or use the network.",
      "expectations": {
        "maxNativeTaskCalls": 0,
        "maxNativeTaskAssignmentAttempts": 0,
        "maxNativeTodoCalls": 0,
        "forbidWorkflowMarkers": true,
        "forbiddenSkills": ["omp-enhancer-workflows"]
      }
    },
    {
      "id": "two-file-natural",
      "category": "positive/two-files",
      "cwd": ".",
      "timeoutSeconds": 480,
      "prompt": "Before any production change, independently challenge two complete implementation plans. Plan A covers plugins/omp-enhancer-core/src/external-action-policy.js; Plan B covers plugins/omp-enhancer-core/src/skill-usage.js. Each plan supplies acceptance criteria, exact local anchors, caller and test seams, one public-behavior assertion with the expected RED and GREEN command, broader verification, and known risks. Check requirement coverage, missing callers or tests, unsafe assumptions, and evidence gaps; no finding is valid when the supplied plan is complete. Compare the two review results and keep every disposition explicit. Do not modify files, run tests, or use the network.",
      "expectations": {
        "maxNativeTaskCalls": 1,
        "maxProjectInspectionCallsBeforeNativeTask": 0,
        "maxProjectInspectionCallsAfterNativeTask": 4,
        "agentArtifactReadPolicy": "preview-once",
        "maxAgentArtifactReadCalls": 2,
        "minNativeTaskAssignmentAttempts": 2,
        "maxNativeTaskAssignmentAttempts": 2,
        "requireNativeTaskBatch": true,
        "requireNativeTaskCompletion": true,
        "requireNativeTaskSubmissionForEveryAssignment": true,
        "requiredObservedSkills": ["code-development", "omp-enhancer-workflows"],
        "requireWorkflowIndexOnlyFirstToolBatch": true,
        "requireWorkflowPlanBeforeResourceLoads": true,
        "forbidResourceProjectSameBatch": true,
        "requireWorkflowReadyAfterLoadsBeforeProjectTools": true,
        "requireExactSelectedWorkflowReferences": true,
        "requireNativeTaskMetadataPrefix": true,
        "requiredNativeTaskAgents": ["plan"],
        "requiredNativeTaskWorkflows": ["code.dev"],
        "requiredNativeTaskWorkflowsPerAssignment": ["code.dev"],
        "requiredNativeTaskSkillsPerAssignment": ["code-development"]
      }
    },
    {
      "id": "cross-plugin-plan-natural",
      "category": "positive/cross-plugin-plans",
      "cwd": ".",
      "prompt": "Before changing this marketplace, independently challenge two complete cross-plugin plans. The generated workflow parity plan covers plugins/omp-enhancer-core and plugins/omp-config; the public review-tool registration parity plan covers plugins/omp-test-enhancer and plugins/omp-fact-checker. Each plan supplies acceptance criteria, exact local anchors, generated or packaged consumers, a focused RED and GREEN command, broader marketplace and packaging checks, and known risks. Report only concrete plan gaps; no finding is valid when coverage is complete. Compare the two review dispositions without changing the plans. Do not modify files, run tests, or use the network.",
      "expectations": {
        "maxNativeTaskCalls": 1,
        "maxProjectInspectionCallsBeforeNativeTask": 0,
        "maxProjectInspectionCallsAfterNativeTask": 4,
        "minNativeTaskAssignmentAttempts": 2,
        "maxNativeTaskAssignmentAttempts": 2,
        "requireNativeTaskCompletion": true,
        "requiredObservedSkills": ["code-development", "omp-enhancer-workflows"],
        "requireWorkflowIndexOnlyFirstToolBatch": true,
        "requireWorkflowPlanBeforeResourceLoads": true,
        "forbidResourceProjectSameBatch": true,
        "requireWorkflowReadyAfterLoadsBeforeProjectTools": true,
        "requireExactSelectedWorkflowReferences": true,
        "requiredNativeTaskAgents": ["plan"],
        "requiredNativeTaskWorkflows": ["omp.plugin"],
        "requiredNativeTaskWorkflowsPerAssignment": ["omp.plugin"],
        "requiredNativeTaskSkillsPerAssignment": ["code-development"]
      }
    }
  ]
}
